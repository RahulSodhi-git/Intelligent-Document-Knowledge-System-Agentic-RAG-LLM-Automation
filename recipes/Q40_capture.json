    {"click": ["app-nav-link[l10n=\"LAYOUT.LEFT_MENU.PAYMENT_METHODS\"]", "text=Payment methods"], "t": 3000}, {"settle": 2400},
    {"snap": 9, "highlight": ["tbody tr:nth-child(1) [data-track-button-id=\"edit-item\"]", "[data-track-button-id=\"edit-item\"]"], "target": "adjust (pencil) / delete (trash)"},
    {"click": ["[data-track-button-id=\"nav-menu-general\"]", "button:has-text(\"General\")"], "t": 2500}, {"wait": 1000},
